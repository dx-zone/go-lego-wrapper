###############################################
# RFC2136 DNS Profile
# Used for dynamic DNS updates via TSIG
###############################################

# Path to the lego ACME client binary (optional if lego is in PATH)
# Example: /usr/local/bin/lego
#LEGO_BIN_PATH=/usr/local/bin/lego

# DNS provider used by lego
# For RFC2136 dynamic updates this value must be:
LEGO_DNS_PROVIDER=rfc2136

# DNS server that will receive the dynamic DNS updates
# Format: hostname:port
#
# The server must:
#  • support RFC2136 dynamic updates
#  • allow updates from this client
#  • allow SOA queries for the zone being updated
#
# Example:
RFC2136_NAMESERVER="ns1.example.net:53"

# TSIG key name configured on the DNS server
# Example: acme-key.
RFC2136_TSIG_KEY="REPLACE_WITH_DNS_TSIG_KEY_NAME"

# TSIG algorithm used for authentication
# Common values:
#   hmac-sha256
#   hmac-sha512
RFC2136_TSIG_ALGORITHM="REPLACE_WITH_TSIG_ALGORITHM"

# TSIG secret associated with the key above
# This must be a Base64-encoded secret provided by the DNS administrator
RFC2136_TSIG_SECRET="REPLACE_WITH_TSIG_SECRET"

# Maximum time to wait for DNS propagation (seconds)
RFC2136_PROPAGATION_TIMEOUT=120

# How often lego checks whether the record has propagated
RFC2136_POLLING_INTERVAL=5

# Normally lego automatically determines the DNS zone.
# If needed, you can manually specify the zone:
# Optional override
# RFC2136_ZONE=example.net