###############################################
# Cloudflare DNS profile
# Used for ACME DNS-01 challenge via Cloudflare API
###############################################

# Path to the lego ACME client binary (optional if lego is in PATH)
# Example: /usr/local/bin/lego
#LEGO_BIN_PATH=/usr/local/bin/lego

# DNS provider to use with lego for ACME DNS-01 challenge
LEGO_DNS_PROVIDER=cloudflare

# Recommended: scoped API token
# Token should have permission:
# Zone:DNS:Edit
# Zone:Zone:Read
CLOUDFLARE_DNS_API_TOKEN_FILE=/run/secrets/cloudflare_dns_token

# Optional propagation tuning
CLOUDFLARE_POLLING_INTERVAL=5
CLOUDFLARE_PROPAGATION_TIMEOUT=120